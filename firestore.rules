rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    function signedIn() {
      return request.auth != null
        && request.auth.token.email != null;
    }

    function email() {
      return request.auth.token.email;
    }

    function isAdmin() {
      return signedIn()
        && exists(/databases/$(database)/documents/admins/$(request.auth.uid))
        && get(/databases/$(database)/documents/admins/$(request.auth.uid)).data.enabled != false;
    }

    function allowDoc() {
      return get(
        /databases/$(database)/documents/betaAllowlist/$(email())
      );
    }

    function isAllowlisted() {
      return signedIn()
        && exists(
          /databases/$(database)/documents/betaAllowlist/$(email())
        )
        && allowDoc().data.enabled == true;
    }

    function isRegistered() {
      return isAllowlisted()
        && allowDoc().data.invitationUsed == true
        && allowDoc().data.registeredUid == request.auth.uid;
    }

    match /admins/{uid} {
      allow get: if signedIn() && uid == request.auth.uid;
      allow list, create, update, delete: if isAdmin();
    }

    match /betaAllowlist/{emailAddress} {
      allow get: if signedIn()
        && (emailAddress == email() || isAdmin());

      allow list, create, delete: if isAdmin();

      allow update: if isAdmin()
        || (
          signedIn()
          && emailAddress == email()
          && resource.data.enabled == true
          && resource.data.invitationUsed == false
          && resource.data.registeredUid == null
          && request.resource.data
            .diff(resource.data)
            .affectedKeys()
            .hasOnly([
              'invitationUsed',
              'registeredUid',
              'registeredAt'
            ])
          && request.resource.data.invitationUsed == true
          && request.resource.data.registeredUid == request.auth.uid
        );
    }

    match /accessCodes/{codeHash} {
      allow get: if isAllowlisted() || isAdmin();
      allow list, create, delete: if isAdmin();

      allow update: if isAdmin()
        || (
          isAllowlisted()
          && resource.data.active == true
          && resource.data.usageCount is int
          && resource.data.maxUses is int
          && request.resource.data.usageCount
            == resource.data.usageCount + 1
          && request.resource.data.usageCount
            <= resource.data.maxUses
          && request.resource.data
            .diff(resource.data)
            .affectedKeys()
            .hasOnly([
              'usageCount',
              'lastUsedAt',
              'lastUsedBy'
            ])
          && request.resource.data.lastUsedBy == request.auth.uid
        );
    }

    match /users/{uid} {
      allow get: if signedIn()
        && (uid == request.auth.uid || isAdmin());

      allow list: if isAdmin();

      allow create: if isAllowlisted()
        && uid == request.auth.uid
        && request.resource.data.email == email()
        && request.resource.data.status == 'active'
        && request.resource.data.plan == 'beta_v1_2'
        && request.resource.data.authProvider == 'google.com'
        && request.resource.data.version == 'v1.2-beta';

      allow update: if isAdmin()
        || (
          signedIn()
          && uid == request.auth.uid
          && isRegistered()
          && request.resource.data
            .diff(resource.data)
            .affectedKeys()
            .hasOnly(['lastLoginAt'])
        );

      allow delete: if isAdmin();
    }
  }
}
